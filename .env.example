# Cloudy credentials — TEMPLATE.
# Copy this file to ".env" (which is gitignored) and fill in the values:
#     cp .env.example .env
# The app loads CLOUDY_* from .env on startup. NEVER commit a filled-in .env.
# See docs/SECRETS.md and docs/AUTH.md.

# --- Microsoft 365 -----------------------------------------------------------
# Public client ID (safe to share) — already baked into the app's defaults.
# Uncomment only to override with your own Entra app registration.
# CLOUDY_MS_CLIENT_ID=dcd8ee18-6e62-4c5a-b01f-86f9556f8fed

# --- Google (Gmail + Calendar) ----------------------------------------------
# From Google Cloud Console -> APIs & Services -> Credentials -> Desktop app.
# The client secret is sensitive: keep it only in your local .env / CI secrets.
CLOUDY_GOOGLE_CLIENT_ID=
CLOUDY_GOOGLE_CLIENT_SECRET=
